{
  "name": "@pinia-orm/axios",
  "version": "2.0.0-alpha.2",
  "description": "Axios plugin for pinia-orm",
  "bugs": {
    "url": "https://github.com/CodeDredd/pinia-orm/issues"
  },
  "homepage": "https://github.com/CodeDredd/pinia-orm",
  "repository": {
    "url": "https://github.com/CodeDredd/pinia-orm.git",
    "type": "git"
  },
  "keywords": [
    "axios",
    "pinia-orm",
    "api"
  ],
  "files": [
    "dist/",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "funding": "https://github.com/sponsors/codedredd",
  "jsdelivr": "dist/index.mjs",
  "unpkg": "dist/index.mjs",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "sideEffects": false,
  "scripts": {
    "build": "unbuild",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s --commit-path . -l @pinia-orm/axios -r 1",
    "size": "size-limit",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "test:ui": "vitest --ui --api 9527",
    "test:watch": "vitest --watch",
    "test:3": "vitest --run",
    "test": "pnpm run test:3"
  },
  "author": {
    "name": "Gregor Becker",
    "email": "gregor@codedredd.de"
  },
  "license": "MIT",
  "peerDependencies": {
    "axios": ">=1.13.2",
    "pinia": ">=3.0.0",
    "pinia-orm": ">=1.9.1 || >=2.0.0-alpha"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.16.0",
    "@size-limit/preset-small-lib": "^11.1.4",
    "@vitest/coverage-v8": "^3.2.7",
    "axios": "^1.18.1",
    "axios-mock-adapter": "^2.0.0",
    "eslint": "^9.39.5",
    "pinia": "^4.0.2",
    "pinia-orm": "workspace:*",
    "size-limit": "^11.1.4",
    "typescript": "^5.8.2",
    "unbuild": "^3.1.0",
    "vitest": "^3.2.7",
    "vue": "^3.5.13"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "2 kB"
    }
  ],
  "engines": {
    "node": ">=22.12.0"
  }
}
